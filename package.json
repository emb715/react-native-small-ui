{
  "name": "react-native-small-ui",
  "version": "1.0.1",
  "description": "Small UI library for React Native",
  "source": "./src/index.tsx",
  "main": "./lib/commonjs/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "import": "./lib/module/index.js",
      "require": "./lib/commonjs/index.js"
    },
    "./theme": {
      "source": "./src/theme-exports.tsx",
      "types": "./lib/typescript/src/theme-exports.d.ts",
      "import": "./lib/module/theme-exports.js",
      "require": "./lib/commonjs/theme-exports.js"
    },
    "./utils": {
      "source": "./src/utils-exports.tsx",
      "types": "./lib/typescript/src/utils-exports.d.ts",
      "import": "./lib/module/utils-exports.js",
      "require": "./lib/commonjs/utils-exports.js"
    },
    "./colormode": {
      "source": "./src/colormode.tsx",
      "types": "./lib/typescript/src/colormode.d.ts",
      "import": "./lib/module/colormode.js",
      "require": "./lib/commonjs/colormode.js"
    },
    "./testing": {
      "source": "./src/testing.tsx",
      "types": "./lib/typescript/src/testing.d.ts",
      "import": "./lib/module/testing.js",
      "require": "./lib/commonjs/testing.js"
    },
    "./presets": {
      "source": "./src/presets.ts",
      "types": "./lib/typescript/src/presets.d.ts",
      "import": "./lib/module/presets.js",
      "require": "./lib/commonjs/presets.js"
    }
  },
  "files": [
    "src",
    "skills",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace react-native-small-ui-example start",
    "build:example": "yarn workspace react-native-small-ui-example expo export --platform web --output-dir ../docs/public/example",
    "test": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{js,ts,tsx}\"",
    "format": "prettier --write \"**/*.{js,ts,tsx}\"",
    "format:check": "prettier --check \"**/*.{js,ts,tsx}\"",
    "bundle:check": "node scripts/bundle-check.js",
    "size": "size-limit",
    "intent:check": "npx @tanstack/intent stale --json",
    "preflight": "yarn typecheck && yarn lint && yarn test && yarn bundle:check && yarn prepare && yarn size",
    "clean": "del-cli lib",
    "prepare": "bob build",
    "postinstall": "lefthook install"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "tanstack-intent"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emb715/react-native-small-ui.git"
  },
  "author": "Ezequiel Benitez <ezequielmartinbenitez@gmail.com> (https://github.com/emb715)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/emb715/react-native-small-ui/issues"
  },
  "homepage": "https://github.com/emb715/react-native-small-ui#readme",
  "devDependencies": {
    "@commitlint/config-conventional": "^17.0.2",
    "@evilmartians/lefthook": "^1.5.0",
    "@react-native/babel-preset": "0.83.6",
    "@react-native/eslint-config": "^0.73.1",
    "@size-limit/preset-small-lib": "^11.0.0",
    "@tanstack/intent": "0.3.2",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/react-native": "^12.6.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.5",
    "@types/lodash": "^4.17.7",
    "@types/react": "^18.2.44",
    "commitlint": "^17.0.2",
    "del-cli": "^5.1.0",
    "esbuild": "^0.28.1",
    "eslint": "^8.51.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-ft-flow": "^3.0.11",
    "eslint-plugin-prettier": "^5.0.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-testing-library": "^7.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.83.6",
    "react-native-builder-bob": "^0.26.0",
    "react-test-renderer": "^18.3.1",
    "size-limit": "^11.0.0",
    "typescript": "^5.2.2"
  },
  "resolutions": {
    "@types/react": "^18.2.44",
    "cross-spawn": "7.0.5",
    "fast-xml-parser": "4.4.1",
    "nanoid": "3.3.8",
    "semver": "7.5.2",
    "shell-quote": "1.10.0",
    "ws": "8.21.0",
    "js-yaml": "5.2.1",
    "@babel/plugin-transform-modules-systemjs": "^7.29.4"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.73.0"
  },
  "workspaces": [
    "example"
  ],
  "packageManager": "yarn@3.6.1",
  "jest": {
    "preset": "react-native",
    "collectCoverage": true,
    "coverageReporters": [
      "json",
      "html"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/",
      "<rootDir>/src/__tests__/coverage",
      "<rootDir>/src/__tests__/exports-map.jest.config.js"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/node_modules/",
      "<rootDir>/lib/",
      "<rootDir>/src/__tests__/componentGroup.types.test.tsx"
    ],
    "setupFiles": [],
    "setupFilesAfterEnv": [
      "./src/__mocks__/jest-setup.ts",
      "./src/__mocks__/zustand.ts"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@react-native",
      "prettier"
    ],
    "rules": {
      "react/react-in-jsx-scope": "off",
      "prettier/prettier": [
        "error",
        {
          "quoteProps": "consistent",
          "singleQuote": true,
          "tabWidth": 2,
          "trailingComma": "es5",
          "useTabs": false
        }
      ]
    }
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ],
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "create-react-native-library": {
    "type": "library",
    "version": "0.38.2"
  },
  "dependencies": {
    "zustand": "^4.5.4"
  },
  "directories": {
    "example": "example"
  },
  "intent": {
    "skills": [
      "skills/react-native-small-ui/SKILL.md"
    ]
  },
  "size-limit": [
    {
      "path": "lib/module/index.js",
      "limit": "10 kB"
    },
    {
      "path": "lib/module/colormode.js",
      "limit": "5 kB"
    },
    {
      "path": "lib/module/utils-exports.js",
      "limit": "5 kB"
    },
    {
      "path": "lib/module/theme-exports.js",
      "limit": "10 kB"
    },
    {
      "path": "lib/module/presets.js",
      "limit": "2 kB"
    }
  ]
}
